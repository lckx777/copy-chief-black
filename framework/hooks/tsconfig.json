{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./compiled",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "removeComments": false,
    "lib": ["ES2020"],
    "types": ["node"],
    "baseUrl": "..",
    "paths": {
      "../.aios-core/*": ["../.aios-core/*"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "compiled", "*.d.ts"]
}
